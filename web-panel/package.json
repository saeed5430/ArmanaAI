{
  "name": "persian-ai-panel",
  "version": "1.0.0",
  "description": "پنل مدیریت دستیار هوش مصنوعی فروشگاهی",
  "main": "electron.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.persian.ai.panel",
    "productName": "پنل مدیریت هوش مصنوعی",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
